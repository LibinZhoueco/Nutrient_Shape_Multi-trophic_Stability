rm(list = ls())

library(tidyverse)
library(vegan)
library(piecewiseSEM)

##### For Taihu Lake datasets
dd <- read.csv("TH_results.csv")

#### Check the relationship between TP and stability metrics
summary(lm(log10(foodweb_sta) ~ log10(mean_TP), data = dd))
summary(lm(log10(trophic_sta) ~ log10(mean_TP), data = dd))
summary(lm(log10(trophic_asyn) ~ log10(mean_TP), data = dd))

#### Then we do the SEM for trophic stability ####
sem_TrophicStability_simp <- psem(
   lm(log(trophic_sta) ~ log(simp_Phytoplankton) +log(species_asynchrony_Zooplankton) +  log(species_asynchrony_Phytoplankton) +
       log(species_stability_Phytoplankton) + log(species_stability_Zooplankton) , data = dd),
  lm(log(species_asynchrony_Phytoplankton) ~  log(mean_TP), data = dd),
  lm(log(species_asynchrony_Zooplankton) ~ log(mean_TP) + log(simp_Phytoplankton) , data = dd),
  lm(log(species_stability_Zooplankton) ~ log(mean_TP) + log(simp_Zooplankton) , data = dd),
  lm(log(simp_Zooplankton) ~ log(mean_TP), data = dd),
  
  log(species_asynchrony_Phytoplankton) %~~% log(species_stability_Phytoplankton),
  #log(species_asynchrony_Zooplankton) %~~% log(species_asynchrony_Phytoplankton),
  #log(simp_Phytoplankton) %~~% log(simp_Zooplankton),
  data = dd)
dSep(sem_TrophicStability_simp)
summary(sem_TrophicStability_simp)

########## SEM for trophic asynchrony ####
sem_TrophicAsynchrony <- psem(
  lm(log(trophic_asyn) ~ log(phytoplankton_biomass), data = dd),
  lm(log(phytoplankton_biomass) ~   log(mean_TP) + log(simp_Phytoplankton),data = dd),
  lm(log(zooplankton_biomass) ~  log(simp_Zooplankton) + log(simp_Phytoplankton) +  log(phytoplankton_biomass), data = dd),
  lm(log(simp_Zooplankton) ~ log(mean_TP), data = dd),
  lm(log(simp_Phytoplankton) ~ log(mean_TP), data = dd),
  lm(log(prop_biomass) ~ log(mean_TP), data = dd),
  
  log(simp_Zooplankton) %~~% log(simp_Phytoplankton),
  log(phytoplankton_biomass) %~~% log(prop_biomass),
  data = dd)
dSep(sem_TrophicAsynchrony)
summary(sem_TrophicAsynchrony)

######### For 30 independent lakes
dd_indLake <- read.csv("DD_Globalresults.csv", check.names = FALSE)

summary(lm(log10(foodweb_sta) ~ log10(TP), data = dd_indLake))
summary(lm(log10(trophic_sta) ~ log10(TP), data = dd_indLake))
summary(lm(log10(trophic_asyn) ~ log10(TP), data = dd_indLake))

#### Then we do the SEM for within-trophic stability ####
sem_TrophicStability_glob_sim <- psem(
  lm(log(trophic_sta) ~ log(Popsasyn_Zooplankton) +  log(Popsasyn_Phytoplankton) +
       log(Popsta_Phytoplankton) + log(simp_Phytoplankton), data = dd_indLake),
  lm(log(Popsasyn_Phytoplankton) ~  log(TP), data = dd_indLake),
  lm(log(Popsasyn_Zooplankton) ~ log(TP) , data = dd_indLake),
  lm(log(Popsta_Phytoplankton) ~    log(TP), data = dd_indLake),
  lm(log(Popsta_Zooplankton) ~ log(simp_Phytoplankton) , data = dd_indLake),
  lm(log(simp_Phytoplankton) ~ log(TP), data = dd_indLake),
  
  log(Popsasyn_Phytoplankton) %~~% log(Popsasyn_Zooplankton),
  log(Popsta_Zooplankton) %~~% log(Popsta_Phytoplankton),
  log(simp_Phytoplankton) %~~% log(simp_Zooplankton),
  
  data = dd_indLake)
dSep(sem_TrophicStability_glob_sim)
summary(sem_TrophicStability_glob_sim)

########################################################## Shapley value decomposition ####
#For Taihu Lake
dd$log_foodweb  <- log10(dd$foodweb_sta)
dd$log_trophic  <- log10(dd$trophic_sta)
dd$log_asyn     <- log10(dd$trophic_asyn)

R2_xt      <- summary(lm(log_foodweb ~ log_trophic, data=dd))$r.squared
R2_xa      <- summary(lm(log_foodweb ~ log_asyn, data=dd))$r.squared
R2_xtxa    <- summary(lm(log_foodweb ~ log_trophic + log_asyn, data=dd))$r.squared
shap_troph <- 0.5*(R2_xt + (R2_xtxa - R2_xa))
shap_asyn  <- 0.5*(R2_xa + (R2_xtxa - R2_xt))

shap_values_Taihu <- data.frame(
  Component = c("Trophic Stability", "Trophic Asynchrony"),
  Shapley_Value = c(shap_troph, shap_asyn)
)
print(shap_values_Taihu)

#For 30 independent lakes
dd_indLake$log_foodweb  <- log10(dd_indLake$foodweb_sta)
dd_indLake$log_trophic  <- log10(dd_indLake$trophic_sta)
dd_indLake$log_asyn     <- log10(dd_indLake$trophic_asyn)
R2_xt_ind      <- summary(lm(log_foodweb ~ log_trophic, data=dd_indLake))$r.squared
R2_xa_ind      <- summary(lm(log_foodweb ~ log_asyn, data=dd_indLake))$r.squared
R2_xtxa_ind    <- summary(lm(log_foodweb ~ log_trophic + log_asyn, data=dd_indLake))$r.squared
shap_troph_ind <- 0.5*(R2_xt_ind + (R2_xtxa_ind - R2_xa_ind))
shap_asyn_ind  <- 0.5*(R2_xa_ind + (R2_xtxa_ind - R2_xt_ind))

shap_values_indLakes <- data.frame(
  Component = c("Trophic Stability", "Trophic Asynchrony"),
  Shapley_Value = c(shap_troph_ind, shap_asyn_ind)
)
print(shap_values_indLakes)
